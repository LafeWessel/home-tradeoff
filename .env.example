# Copy to .env and fill in real keys.
# All keys are FREE and self-service.

# Census Bureau API key — https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# BLS API v2 key (optional, raises rate limit) — https://data.bls.gov/registrationEngine/
BLS_API_KEY=

# FBI Crime Data Explorer key (api.usa.gov / api.data.gov) — https://api.data.gov/signup/
FBI_API_KEY=

# NOAA NCEI Climate Data Online token — https://www.ncdc.noaa.gov/cdo-web/token
NOAA_API_TOKEN=

# Backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8765
DATABASE_URL=sqlite:///./data.db

# How long to cache HTTP responses by default (seconds)
HTTP_CACHE_TTL=2592000
